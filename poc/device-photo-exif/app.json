{
  "expo": {
    "name": "Device Photo EXIF PoC",
    "slug": "device-photo-exif-poc",
    "version": "1.0.0",
    "orientation": "portrait",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "여행 사진을 자동으로 분류하기 위해 사진첩에 접근합니다."
      }
    },
    "android": {
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "여행 사진을 자동으로 분류하기 위해 사진첩에 접근합니다.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}
